[sub_resource type="GDScript" id="GDScript_5j3c2"]
script/source = "extends Area2D
class_name Projectile

@export var speed: float = 150.0
@export var damage: int = 20
@export var knockback_force: float = 150.0

@onready var anim_sprite: AnimatedSprite2D = $AnimatedSprite2D
@onready var notifier: VisibleOnScreenNotifier2D = $VisibleOnScreenNotifier2D

var _direction: Vector2 = Vector2.ZERO
var _hit: bool = false  # evita doppi colpi

func _ready() -> void:
	area_entered.connect(_on_area_entered)
	notifier.screen_exited.connect(queue_free)

## Chiamato da SpellCaster dopo l'istanza.
func launch(direction: Vector2) -> void:
	_direction = direction
	# _play_fly_anim(direction)

func _physics_process(delta: float) -> void:
	if _hit:
		return
	position += _direction * speed * delta

func _on_area_entered(area: Area2D) -> void:
	if _hit:
		return
	# Colpisce solo hurtbox nemiche (layer 7)
	if not area is Hurtbox:
		return
	_hit = true
	set_physics_process(false)
	var target = area.get_parent()
	if target.has_node(\"HealthComponent\"):
		target.get_node(\"HealthComponent\").take_damage(damage, global_position, knockback_force)
	#  _play_impact()

func _direction_to_suffix(dir: Vector2) -> String:
	if abs(dir.x) >= abs(dir.y):
		return \"right\" if dir.x > 0.0 else \"left\"
	else:
		return \"down\" if dir.y > 0.0 else \"up\"
"

